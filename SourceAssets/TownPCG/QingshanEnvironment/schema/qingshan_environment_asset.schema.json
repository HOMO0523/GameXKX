{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gamexxk.local/schemas/qingshan_environment_asset.schema.json",
  "title": "GameXXK Qingshan Environment Concept Asset",
  "description": "Documented contract for concept-only Qingshan environment asset records. The Python validator remains authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_id",
    "display_name",
    "category",
    "batch",
    "priority",
    "status",
    "style_profile",
    "intended_zone",
    "gameplay_role",
    "target_dimensions_m",
    "pivot",
    "forward_axis",
    "palette",
    "silhouette_keywords",
    "material_language",
    "negative_prompt",
    "dependencies",
    "detail_budget",
    "source_provenance",
    "reference_images",
    "generation",
    "unreal",
    "pcg",
    "workflow_gates",
    "acceptance"
  ],
  "allOf": [
    {
      "if": {
        "properties": {"asset_id": {"const": "BLD_QS_S_A_HOUSE"}},
        "required": ["asset_id"]
      },
      "then": {
        "required": [
          "category",
          "style_profile",
          "source_provenance",
          "generation",
          "reference_images",
          "building",
          "roof",
          "retopo_target_quads"
        ],
        "properties": {
          "category": {"const": "building"},
          "style_profile": {"const": "QS_InkToon_Building_v2"},
          "display_name": {"const": "青山镇小民居 A"},
          "gameplay_role": {"const": "small_house"},
          "target_dimensions_m": {"const": [3.6, 4.2, 3.8]},
          "intended_zone": {"const": ["courtyard"]},
          "silhouette_keywords": {
            "const": ["compact_two_storey", "curved_double_slope", "offset_entrance"]
          },
          "material_language": {
            "const": [
              "QS_InkToon_Building_v2",
              "two_to_three_value_bands",
              "dry_brush_edges"
            ]
          },
          "palette": {
            "const": [
              "warm_off_white",
              "dark_teal_ink",
              "jade_green",
              "blue_gray",
              "warm_ochre",
              "orange"
            ]
          },
          "source_provenance": {
            "required": ["style_profile", "source_kind"],
            "properties": {
              "style_profile": {"const": "QS_InkToon_Building_v2"},
              "source_kind": {"const": "project_concept"}
            }
          },
          "generation": {
            "properties": {
              "required_view_kinds": {"const": ["hero_3q"]},
              "max_generation_calls": {"const": 6}
            }
          },
          "reference_images": {
            "minItems": 1,
            "maxItems": 1,
            "items": {"properties": {"kind": {"const": "hero_3q"}}}
          },
          "retopo_target_quads": {"const": 50000},
          "roof": {
            "const": {"form": "curved_double_slope", "primary_color": "orange"}
          },
          "building": {
            "required": ["model_pipeline", "scale_anchor", "visual_contract"],
            "not": {
              "anyOf": [
                {"required": ["golden_contract"]}
              ]
            },
            "properties": {
              "scale_anchor": {"const": "BLD_QS_L_A_MARKET_SHOP"},
              "model_pipeline": {
                "const": {
                  "approved_quad_face_range": [45000, 55000],
                  "material_stage": "after_retopology",
                  "source": "Tripo_high_precision",
                  "target_quad_faces": 50000,
                  "topology": "quad_dominant"
                }
              },
              "visual_contract": {
                "const": {
                  "building_type": "compact_two_storey_small_residence",
                  "entrance": {"door_type": "chunky_double_leaf", "placement": "offset"},
                  "roof": {"color": "orange", "form": "curved_double_slope"},
                  "structure": {"beam_column_language": "chunky"},
                  "windows": {
                    "frame": "wide",
                    "glazing": "warm_yellow_rice_paper",
                    "micro_grid": "none",
                    "quantity": "few"
                  }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {"style_profile": {"const": "QS_InkToon_v1"}}
      }
    },
    {
      "if": {
        "properties": {"style_profile": {"const": "QS_InkToon_v1"}},
        "required": ["style_profile"]
      },
      "then": {
        "properties": {
          "source_provenance": {
            "properties": {"style_profile": {"const": "QS_InkToon_v1"}}
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {"const": "building"},
          "asset_id": {"not": {"const": "BLD_QS_M_A_INN"}}
        },
        "required": ["category", "asset_id", "building"]
      },
      "then": {
        "properties": {
          "building": {
            "not": {
              "anyOf": [
                {"required": ["golden_contract"]}
              ]
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "asset_id": {
      "type": "string",
      "pattern": "^(REF|BLD|LMK|ENV|P2D|SRF|KIT|PROP)_QS_[A-Z0-9_]+$"
    },
    "display_name": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "category": {
      "enum": [
        "reference",
        "registry",
        "building",
        "landmark",
        "near_mountain",
        "far_mountain",
        "rock_kit",
        "paper2d_plant",
        "surface",
        "linear_kit",
        "prop_kit"
      ]
    },
    "batch": {
      "enum": [
        "REGISTRY",
        "B0",
        "B1",
        "B2",
        "B3"
      ]
    },
    "priority": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "status": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "style_profile": {
      "enum": ["QS_InkToon_v1", "QS_InkToon_Building_v2"]
    },
    "intended_zone": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "gameplay_role": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "target_dimensions_m": {
      "$ref": "#/$defs/positiveTriple"
    },
    "pivot": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "forward_axis": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "palette": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "silhouette_keywords": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "material_language": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "negative_prompt": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "dependencies": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "detail_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thumbnail_readability_px",
        "max_primary_masses",
        "max_secondary_internal_stroke_groups",
        "main_value_bands",
        "shadow_accent_bands",
        "forbidden_micro_detail",
        "object_rule",
        "prompt_instruction"
      ],
      "properties": {
        "thumbnail_readability_px": {
          "const": 128
        },
        "max_primary_masses": {
          "const": 3
        },
        "max_secondary_internal_stroke_groups": {
          "const": 5
        },
        "main_value_bands": {
          "const": 2
        },
        "shadow_accent_bands": {
          "const": 1
        },
        "forbidden_micro_detail": {
          "const": [
            "individual_roof_tiles",
            "repeated_window_lattices",
            "leaf_by_leaf_foliage",
            "stone_or_pebble_tessellation",
            "tiny_prop_piles"
          ]
        },
        "object_rule": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "prompt_instruction": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "review_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visual_risks",
        "production_guidance"
      ],
      "properties": {
        "visual_risks": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "production_guidance": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "source_provenance": {
      "type": "object",
      "minProperties": 1,
      "required": ["style_profile"],
      "properties": {
        "style_profile": {
          "enum": ["QS_InkToon_v1", "QS_InkToon_Building_v2"]
        }
      }
    },
    "reference_images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "approval_state",
          "file_stub"
        ],
        "properties": {
          "kind": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "camera": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "background": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "required_annotations": {
            "$ref": "#/$defs/nonEmptyStringArray"
          },
          "approval_state": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "file_stub": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "output_path": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "version": {
            "enum": [
              "v001",
              "v002",
              "v003"
            ]
          },
          "rejection_reason": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "generation_input_paths": {
            "description": "Actual direct tool inputs only. The current built-in imagegen runtime accepts at most five direct images per successful call.",
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/projectRootRelativePosixPath"
            }
          },
          "generation_reference_lineage": {
            "description": "Complete stable-reference ancestry. This lineage is not limited to five entries; it may exceed the direct tool-input cap.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/projectRootRelativePosixPath"
            }
          },
          "generation_prompt": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "dependentRequired": {
          "generation_input_paths": [
            "generation_reference_lineage",
            "generation_prompt"
          ],
          "generation_reference_lineage": [
            "generation_input_paths",
            "generation_prompt"
          ],
          "generation_prompt": [
            "generation_input_paths",
            "generation_reference_lineage"
          ]
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "use_case",
        "asset_type",
        "required_view_kinds",
        "max_versions_per_view",
        "max_generation_calls",
        "generation_calls_used",
        "blocked_after_revisions"
      ],
      "properties": {
        "use_case": {
          "const": "stylized-concept"
        },
        "asset_type": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required_view_kinds": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "max_versions_per_view": {
          "const": 3
        },
        "max_generation_calls": {
          "type": "integer",
          "minimum": 0
        },
        "generation_calls_used": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_after_revisions": {
          "const": 2
        },
        "prompt": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "input_images": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/nonEmptyString"
              },
              {
                "type": "object",
                "minProperties": 1
              }
            ]
          }
        },
        "input_image_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "minProperties": 1
          }
        },
        "prompt_sections": {
          "type": "object",
          "minProperties": 1
        },
        "scene_backdrop": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "subject": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "style_medium": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "composition_framing": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "lighting_mood": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "palette": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "constraints": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "avoid": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "unreal": {
      "type": "object",
      "minProperties": 1
    },
    "pcg": {
      "type": "object",
      "minProperties": 1
    },
    "workflow_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style_locked",
        "reference_approved",
        "concept_generation_allowed",
        "batch_unlocked",
        "previous_batch_approved",
        "batch_approval_id",
        "model_or_sprite_production_allowed",
        "tripo_allowed",
        "ue_import_allowed"
      ],
      "properties": {
        "style_locked": {
          "type": "boolean"
        },
        "reference_approved": {
          "type": "boolean"
        },
        "concept_generation_allowed": {
          "type": "boolean"
        },
        "batch_unlocked": {
          "type": "boolean"
        },
        "previous_batch_approved": {
          "type": "boolean"
        },
        "batch_approval_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "model_or_sprite_production_allowed": {
          "const": false
        },
        "tripo_allowed": {
          "const": false
        },
        "ue_import_allowed": {
          "const": false
        }
      }
    },
    "acceptance": {
      "type": "object",
      "minProperties": 1
    },
    "building": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_pipeline", "scale_anchor"],
      "properties": {
        "model_pipeline": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "approved_quad_face_range",
            "material_stage",
            "source",
            "target_quad_faces",
            "topology"
          ],
          "properties": {
            "approved_quad_face_range": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {"type": "integer", "minimum": 1}
            },
            "material_stage": {
              "enum": ["ue_after_gate1_geometry_approval", "after_retopology"]
            },
            "source": {
              "enum": [
                "Blender_procedural_golden",
                "Blender_modular_derivative",
                "Tripo_high_precision"
              ]
            },
            "target_quad_faces": {"type": "integer", "minimum": 1},
            "topology": {"const": "quad_dominant"}
          }
        },
        "scale_anchor": {"$ref": "#/$defs/nonEmptyString"},
        "golden_contract": {"type": "object", "minProperties": 1},
        "visual_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["building_type", "entrance", "roof", "structure", "windows"],
          "properties": {
            "building_type": {"const": "compact_two_storey_small_residence"},
            "entrance": {
              "type": "object",
              "additionalProperties": false,
              "required": ["door_type", "placement"],
              "properties": {
                "door_type": {"const": "chunky_double_leaf"},
                "placement": {"const": "offset"}
              }
            },
            "roof": {
              "type": "object",
              "additionalProperties": false,
              "required": ["color", "form"],
              "properties": {
                "color": {"const": "orange"},
                "form": {"const": "curved_double_slope"}
              }
            },
            "structure": {
              "type": "object",
              "additionalProperties": false,
              "required": ["beam_column_language"],
              "properties": {"beam_column_language": {"const": "chunky"}}
            },
            "windows": {
              "type": "object",
              "additionalProperties": false,
              "required": ["frame", "glazing", "micro_grid", "quantity"],
              "properties": {
                "frame": {"const": "wide"},
                "glazing": {"const": "warm_yellow_rice_paper"},
                "micro_grid": {"const": "none"},
                "quantity": {"const": "few"}
              }
            }
          }
        }
      }
    },
    "landmark": {
      "type": "object",
      "minProperties": 1
    },
    "environment": {
      "type": "object",
      "minProperties": 1
    },
    "paper2d": {
      "type": "object",
      "minProperties": 1
    },
    "surface": {
      "type": "object",
      "minProperties": 1
    },
    "kit": {
      "type": "object",
      "minProperties": 1
    },
    "registry": {
      "type": "object",
      "minProperties": 1
    },
    "variant_limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "size_class": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "use": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "footprint_m": {
      "$ref": "#/$defs/positivePair"
    },
    "entrance_axis": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "roof": {
      "type": "object",
      "minProperties": 1
    },
    "eave_height_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "door_socket": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "retopo_target_quads": {
      "type": "integer",
      "minimum": 1
    },
    "texture_resolution": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "simple_collision_required": {
      "type": "boolean"
    },
    "allowed_cluster_roles": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "source_canvas_px": {
      "$ref": "#/$defs/positivePair"
    },
    "sprite_cell_px": {
      "$ref": "#/$defs/positivePair"
    },
    "pixels_per_unreal_unit": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "pivot_mode": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "card_world_size_m": {
      "$ref": "#/$defs/positivePair"
    },
    "facing_mode": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "depth_layer": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "atlas_group": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "wind_frames": {
      "enum": [
        4,
        5
      ]
    },
    "animated_variants": {
      "const": [
        "A"
      ]
    },
    "atlas_cell_count": {
      "type": "integer",
      "minimum": 1
    },
    "masked_material": {
      "type": "boolean"
    },
    "cluster_size": {
      "type": "integer",
      "minimum": 1
    },
    "spacing_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "cull_distance_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "collision": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "object",
          "minProperties": 1
        }
      ]
    },
    "ground_trace_required": {
      "type": "boolean"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "projectRootRelativePosixPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "positivePair": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number",
        "exclusiveMinimum": 0
      }
    },
    "positiveTriple": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number",
        "exclusiveMinimum": 0
      }
    }
  }
}
